---
import "../styles/global.css";
import PostHog from "../components/posthog.astro";

export interface Props {
	title: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
}

const {
	title,
	description = "Zabaca builds AI-powered tools for the future of work.",
	canonicalUrl,
	ogImage
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="canonical" href={canonicalUrl || Astro.url.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl || Astro.url.href} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Preconnect to speed up font loading -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<!-- Load Inter font with extra bold weight -->
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
		
		<!-- DNS prefetch for any external resources -->
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		
		<!-- Optimize CSS delivery -->
		<style>
			/* Critical inline styles for faster initial paint */
			body {
				margin: 0;
				min-height: 100vh;
				font-synthesis: none;
				text-rendering: optimizeLegibility;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}
		</style>
		
		<!-- PostHog Analytics -->
		<PostHog />
	</head>
	<body>
		<slot />
		<footer class="zabaca-footer">
			<div class="footer-container">
				<div class="footer-brand">
					<a href="/" class="footer-logo">Zabaca</a>
					<p class="footer-company">A product of Zabaca LLC</p>
				</div>
				<div class="footer-contact">
					<p class="footer-heading">Contact &amp; Support</p>
					<p>
						Questions or support requests:
						<a href="mailto:hello@zabaca.com">hello@zabaca.com</a>
					</p>
					<p>
						<a href="/press">Press</a>
						<span class="footer-sep">·</span>
						<a href="/careers">Careers</a>
					</p>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; {new Date().getFullYear()} Zabaca LLC. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--accent: 124, 58, 237;
		--accent-gradient: linear-gradient(45deg, rgb(var(--accent)), #da62c4 30%, white 60%);
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		background-color: #FFFFFF;
	}
	code {
		font-family: Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
			Bitstream Vera Sans Mono, Courier New, monospace;
	}

	/* Global footer */
	.zabaca-footer {
		background-color: #131416;
		color: #e5e7eb;
		font-family: 'Fredoka', 'Inter', system-ui, sans-serif;
		padding: 3rem 1.5rem 1.5rem;
	}
	.zabaca-footer a {
		color: #4ff37d;
		text-decoration: none;
	}
	.zabaca-footer a:hover {
		text-decoration: underline;
	}
	.footer-container {
		max-width: 1280px;
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		justify-content: space-between;
		align-items: flex-start;
	}
	.footer-logo {
		font-size: 1.5rem;
		font-weight: 700;
		color: #ffffff !important;
		letter-spacing: -0.03em;
	}
	.footer-company {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
		color: #9ca3af;
	}
	.footer-heading {
		font-weight: 600;
		color: #ffffff;
		margin: 0 0 0.5rem;
	}
	.footer-contact p {
		margin: 0.25rem 0;
		font-size: 0.95rem;
	}
	.footer-sep {
		margin: 0 0.5rem;
		color: #6b7280;
	}
	.footer-bottom {
		max-width: 1280px;
		margin: 2rem auto 0;
		padding-top: 1.5rem;
		border-top: 1px solid #2a2b2e;
		font-size: 0.85rem;
		color: #9ca3af;
		text-align: center;
	}
	.footer-bottom p {
		margin: 0;
	}
</style>